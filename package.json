{
  "name": "llm-visualizador",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Sitio interactivo para el taller 'Modelos de Lenguaje en Salud' — Clínica Alemana",
  "scripts": {
    "dev": "vite",
    "dev:cf": "wrangler pages dev --port 8788 -- npm run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241200.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
